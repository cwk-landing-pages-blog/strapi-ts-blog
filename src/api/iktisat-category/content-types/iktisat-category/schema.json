{
  "kind": "collectionType",
  "collectionName": "iktisat_categories",
  "info": {
    "singularName": "iktisat-category",
    "pluralName": "iktisat-categories",
    "displayName": "Iktisat Category",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 30
    },
    "iktisat_profile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::iktisat-profile.iktisat-profile"
    },
    "description": {
      "type": "text",
      "maxLength": 255
    },
    "isPublic": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "iconName": {
      "type": "enumeration",
      "enum": [
        "general",
        "cat",
        "website",
        "priceTag",
        "github",
        "barber",
        "clothes",
        "eatingOut",
        "fuel",
        "entertainment",
        "family",
        "kids",
        "gifts",
        "holidays",
        "home",
        "market",
        "shoppingBag",
        "shoppingCart",
        "travelPlane",
        "travelBus",
        "travelCar",
        "transport",
        "hospital",
        "medicine",
        "monetize"
      ]
    },
    "color": {
      "type": "string",
      "default": "#22d3ee",
      "maxLength": 7,
      "required": true,
      "minLength": 7
    },
    "group": {
      "type": "enumeration",
      "enum": [
        "housing",
        "utilities",
        "groceries",
        "transportation",
        "insurance",
        "personalCare",
        "entertainment",
        "clothing",
        "education",
        "miscellaneous",
        "taxes",
        "children",
        "investments",
        "vacation",
        "technology",
        "general",
        "charity",
        "tools",
        "other"
      ]
    }
  }
}
