{
  "kind": "collectionType",
  "collectionName": "iktisat_debts",
  "info": {
    "singularName": "iktisat-debt",
    "pluralName": "iktisat-debts",
    "displayName": "Iktisat Debt",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "iktisat_profile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::iktisat-profile.iktisat-profile"
    },
    "name": {
      "type": "string",
      "maxLength": 50,
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "give",
        "take"
      ],
      "required": true,
      "default": "take"
    },
    "finishDate": {
      "type": "date"
    },
    "notification": {
      "type": "enumeration",
      "enum": [
        "never",
        "daily",
        "weekly",
        "monthly",
        "yearly"
      ],
      "required": true,
      "default": "never"
    },
    "initial_value": {
      "type": "decimal"
    }
  }
}
