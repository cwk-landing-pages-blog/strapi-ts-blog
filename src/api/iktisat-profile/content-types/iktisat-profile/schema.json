      "type": "boolean",
      "default": false,
      "required": true
    },
    "isMarried": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "transaction": {
      "displayName": "transaction",
      "type": "component",
      "repeatable": true,
      "component": "business.transaction"
    },
    "iktisat_accounts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::iktisat-account.iktisat-account",
      "mappedBy": "iktisat_profile"
    },
    "settings": {
      "displayName": "settings",
      "type": "component",
      "repeatable": false,
      "component": "blocks.settings"
    }
