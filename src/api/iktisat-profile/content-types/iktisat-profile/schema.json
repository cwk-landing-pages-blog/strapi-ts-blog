{
  "kind": "collectionType",
  "collectionName": "iktisat_profiles",
  "info": {
    "singularName": "iktisat-profile",
    "pluralName": "iktisat-profiles",
    "displayName": "Iktisat Profile",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "iktisat_user": {
      "type": "relation",
